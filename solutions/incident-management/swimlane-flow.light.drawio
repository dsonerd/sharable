        </mxCell>

        <!-- INCIDENT CLOSED -->
        <mxCell id="152" value="&lt;b&gt;INCIDENT CLOSED&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;RCA published · Actions in backlog&lt;br&gt;Knowledge Base updated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052E16;strokeColor=#22C55E;strokeWidth=2.5;fontColor=#BBF7D0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1460" y="575" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- MANAGEMENT lane — Row 1: notifications       -->
        <!-- ============================================ -->
        <mxCell id="160" value="&lt;b&gt;Notified&lt;/b&gt; (P1/P2)&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;Approve escalation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#0EA5E9;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
