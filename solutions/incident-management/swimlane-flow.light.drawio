        </mxCell>

        <!-- Infra preliminary P → Infra Response -->
        <mxCell id="311" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=2;strokeColor=#EF4444;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;" edge="1" source="119" target="130" parent="1">
          <mxGeometry relative="1" as="geometry">
