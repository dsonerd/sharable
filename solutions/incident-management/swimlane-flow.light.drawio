        <mxCell id="341" value="&lt;font style=&quot;fontSize:8&quot; color=&quot;#059669&quot;&gt;&lt;b&gt;Approved&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#10B981;dashed=1;dashPattern=5 3;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" edge="1" source="170" target="131" parent="1">
