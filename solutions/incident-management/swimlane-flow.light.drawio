              <mxPoint x="695" y="297"/>
              <mxPoint x="695" y="396"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- EDGES — L1/L2 lane → Response Team lane      -->
        <!-- (Infra track via x=700, App track via x=710) -->
        <!-- ============================================ -->

        <!-- Infra KB YES → Infra Response -->
        <mxCell id="310" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=2;strokeColor=#EF4444;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="117" target="130" parent="1">
          <mxGeometry relative="1" as="geometry">
