        </mxCell>

        <!-- ============================================ -->
        <!-- EDGES — Main flow                            -->
        <!-- ============================================ -->

        <!-- Detect → Receive -->
        <mxCell id="300" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="100" target="101" parent="1">
