        </mxCell>
        <mxCell id="161" value="&lt;font style=&quot;fontSize:9&quot;&gt;Receive status updates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#0EA5E9;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
