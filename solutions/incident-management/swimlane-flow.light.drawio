        <!-- Monitor → Reporter confirms? -->
        <mxCell id="316" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#10B981;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="140" target="141" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Reporter confirms → YES → Service Restored -->
        <mxCell id="317" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#10B981;fontSize=9;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="141" target="142" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Reporter confirms → NO → back to App Response -->
        <mxCell id="318" value="&lt;font color=&quot;#EF4444&quot;&gt;&lt;b&gt;Not resolved&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#EF4444;dashed=1;dashPattern=5 3;fontSize=9;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" source="141" target="131" parent="1">
          <mxGeometry relative="1" as="geometry">
