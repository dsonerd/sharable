        <!-- Mgmt Review → Incident Closed -->
        <mxCell id="321" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#22C55E;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="151" target="152" parent="1">
          <mxGeometry relative="1" as="geometry">
