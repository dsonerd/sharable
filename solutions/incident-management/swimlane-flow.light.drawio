              <mxPoint x="815" y="740"/>
              <mxPoint x="790" y="740"/>
              <mxPoint x="790" y="785"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Service restored → Mgmt notified of restoration -->
        <mxCell id="332" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1;strokeColor=#94A3B8;dashed=1;dashPattern=5 3;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="142" target="162" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- EDGES — Approval gate (P1/P2 App Incident)   -->
        <!-- Request goes down, approval returns up-right -->
        <!-- ============================================ -->

        <!-- App Response → Mgmt Approve (request approval to deploy) -->
        <mxCell id="340" value="&lt;font style=&quot;fontSize:8&quot; color=&quot;#D97706&quot;&gt;P1/P2: approval&lt;br&gt;to deploy&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#F59E0B;dashed=1;dashPattern=5 3;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="131" target="170" parent="1">
