        </mxCell>

        <!-- App response (blackboxed) -->
        <mxCell id="131" value="&lt;b&gt;Application Response&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;Root cause · Develop fix&lt;br&gt;QA validate · Deploy via CI/CD&lt;br&gt;&lt;i&gt;IC coordinates if P1/P2&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#F59E0B;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="600" width="190" height="70" as="geometry"/>
        </mxCell>

        <!-- Escalation note — P1 protocol -->
        <mxCell id="132" value="&lt;font style=&quot;fontSize:9&quot;&gt;&lt;b&gt;P1 → Major Incident Protocol&lt;/b&gt;&lt;br&gt;War room · Bridge call&lt;br&gt;Escalate to L3 / Vendor if needed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;strokeWidth=1;fontSize=9;dashed=1;dashPattern=4 2;" vertex="1" parent="1">
          <mxGeometry x="930" y="500" width="185" height="48" as="geometry"/>
        </mxCell>

        <!-- Status updates note -->
        <mxCell id="133" value="&lt;font style=&quot;fontSize:9&quot;&gt;Status updates:&lt;br&gt;&lt;b&gt;P1&lt;/b&gt; every 30 min · &lt;b&gt;P2&lt;/b&gt; every 1 hr&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#A78BFA;strokeWidth=1;fontSize=9;fontColor=#6D28D9;dashed=1;dashPattern=3 3;" vertex="1" parent="1">
          <mxGeometry x="930" y="640" width="180" height="32" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- STAGE 4: VERIFY — Response Team lane         -->
        <!-- ============================================ -->
        <mxCell id="140" value="&lt;b&gt;Monitor 15 min&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;Check for regression&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#10B981;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="500" width="140" height="42" as="geometry"/>
