              <mxPoint x="628" y="455"/>
              <mxPoint x="710" y="455"/>
              <mxPoint x="710" y="649"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- EDGES — Response → Verify → Close            -->
        <!-- ============================================ -->

        <!-- Infra Response → Monitor -->
        <mxCell id="314" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="130" target="140" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- App Response → Monitor -->
        <mxCell id="315" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" source="131" target="140" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="635"/>
              <mxPoint x="990" y="542"/>
