            </Array>
          </mxGeometry>
        </mxCell>

        <!-- KB Infra → YES → Assign P from KB -->
        <mxCell id="306" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#EF4444;fontSize=9;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="115" target="117" parent="1">
          <mxGeometry relative="1" as="geometry"/>
