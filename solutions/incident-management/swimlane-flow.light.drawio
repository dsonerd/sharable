        <!-- KB App → NO → Collaborate with Tech Team -->
        <mxCell id="309" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#F59E0B;fontSize=9;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" source="116" target="120" parent="1">
          <mxGeometry relative="1" as="geometry">
