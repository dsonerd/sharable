        <!-- Reporter confirms? -->
        <mxCell id="141" value="Reporter&lt;br&gt;confirms?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#10B981;strokeWidth=2;fontSize=10;fontStyle=1;" vertex="1" parent="1">
