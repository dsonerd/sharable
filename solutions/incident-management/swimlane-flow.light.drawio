              <mxPoint x="980" y="612"/>
              <mxPoint x="980" y="670"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Service Restored → Blameless RCA -->
        <mxCell id="319" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="142" target="150" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1260" y="709"/>
              <mxPoint x="1260" y="530"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- RCA → Mgmt Review (clean vertical drop) -->
        <mxCell id="320" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#0EA5E9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="150" target="151" parent="1">
          <mxGeometry relative="1" as="geometry"/>
