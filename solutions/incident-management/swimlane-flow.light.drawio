        <mxCell id="162" value="&lt;font style=&quot;fontSize:9&quot;&gt;Notified of restoration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#0EA5E9;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1090" y="785" width="130" height="32" as="geometry"/>
        </mxCell>

        <!-- Mgmt review (P1/P2 only) -->
        <mxCell id="151" value="&lt;b&gt;Review RCA &amp;amp; Sign Off&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;P1/P2 only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0EA5E9;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1290" y="785" width="155" height="38" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- MANAGEMENT lane — Row 2: approval gate       -->
        <!-- ============================================ -->
        <mxCell id="170" value="&lt;b&gt;Approve Fix Deploy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;fontSize:9&quot;&gt;P1/P2 App Incident&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="890" y="870" width="140" height="38" as="geometry"/>
        </mxCell>

        <!-- ============================================ -->
        <!-- EDGES — Main flow                            -->
        <!-- ============================================ -->

        <!-- Detect → Receive -->
        <mxCell id="300" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="100" target="101" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Receive → Real incident? -->
        <mxCell id="301" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="101" target="110" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Real incident? → NO → Not an Incident -->
        <mxCell id="302" value="NO" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#6B7280;fontSize=10;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="110" target="111" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Real incident? → YES → Infra healthy? -->
        <mxCell id="303" value="YES" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=1.5;strokeColor=#475569;fontSize=10;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="110" target="112" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Infra healthy? → NO (Infra broken) → KB Infra -->
        <mxCell id="304" value="&lt;font color=&quot;#EF4444&quot;&gt;&lt;b&gt;NO&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=2;strokeColor=#EF4444;fontSize=9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="112" target="115" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Infra healthy? → YES (App issue) → KB App -->
        <mxCell id="305" value="&lt;font color=&quot;#D97706&quot;&gt;&lt;b&gt;YES&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeWidth=2;strokeColor=#F59E0B;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="112" target="116" parent="1">
          <mxGeometry relative="1" as="geometry">
