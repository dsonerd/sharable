          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{namespace=\"system-a-prod\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"system-a-prod\"}[5m])) * 100",
