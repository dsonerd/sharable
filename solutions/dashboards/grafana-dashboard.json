{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for EKS metrics (AMP or self-hosted)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "id": null,
  "uid": "eks-platform-observability",
  "title": "EKS Platform Observability",
  "description": "TV dashboard — 4 EKS systems at a glance for leadership",
  "tags": ["eks", "platform", "observability", "tv"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h"]
  },
  "timezone": "",
  "links": [],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "type": "row",
      "title": "System A — eks-prod-apse1 / system-a-prod",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Health Status",
      "id": 101,
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "min(kube_deployment_status_replicas_ready{namespace=\"system-a-prod\"} / kube_deployment_status_replicas{namespace=\"system-a-prod\"})",
          "legendFormat": "",
          "refId": "A",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9999 }
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0.9999,
                "to": 100,
                "result": { "text": "HEALTHY", "index": 0 }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.5,
                "to": 0.9998,
                "result": { "text": "DEGRADED", "index": 1 }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0.4999,
                "result": { "text": "DOWN", "index": 2 }
              }
            }
          ],
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "gauge",
      "title": "Uptime / SLA",
      "id": 102,
      "gridPos": { "h": 6, "w": 4, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(avg_over_time(up{job=\"system-a\", namespace=\"system-a-prod\"}[30d])) * 100",
          "legendFormat": "",
          "refId": "A",
          "editorMode": "code",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 95,
          "max": 100,
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.95 }
            ]
          },
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "showThresholdMarkers": true,
        "showThresholdLabels": false,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Latency P95",
      "id": 103,
